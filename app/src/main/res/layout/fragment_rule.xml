<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F8FAFC"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="이용 규정"
            android:textSize="26sp"
            android:textStyle="bold"
            android:textColor="#0F1E36"
            android:layout_marginBottom="24dp"
            android:letterSpacing="-0.03"/>

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:cardCornerRadius="16dp"
            app:cardElevation="0dp"
            app:strokeWidth="1dp"
            app:strokeColor="#E2E8F0"
            app:cardBackgroundColor="#FFFFFF">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="📌 시설 이용 기본 수칙"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:textColor="#0F1E36"
                    android:layout_marginBottom="12dp"/>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="• 예약 시간 엄수 (시작 및 종료 시간 미준수 시 페널티 부과)\n• 음식물 반입 금지 (음료 및 간단한 스낵류 제외)\n• 퇴실 시 멀티탭 전원 차단 및 기자재 정리 정돈 필수"
                    android:textColor="#475569"
                    android:textSize="14sp"
                    android:lineSpacingExtra="6dp"/>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:cardCornerRadius="16dp"
            app:cardElevation="0dp"
            app:strokeWidth="1dp"
            app:strokeColor="#E2E8F0"
            app:cardBackgroundColor="#FFFFFF">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="⏰ 예약 및 대여 제한 사양"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:textColor="#0F1E36"
                    android:layout_marginBottom="12dp"/>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="• 1인당 일일 최대 이용 시간: 3시간 제한\n• 최소 예약 가능 인원: 각 스터디룸 규격별 기준 준수\n• 당일 예약 취소는 시작 시간 최소 1시간 전까지만 가능"
                    android:textColor="#475569"
                    android:textSize="14sp"
                    android:lineSpacingExtra="6dp"/>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="16dp"
            app:cardElevation="0dp"
            app:strokeWidth="1dp"
            app:strokeColor="#FCA5A5"
            app:cardBackgroundColor="#FEF2F2">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="⚠️ 무단 불참(No-Show) 제재 조치"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:textColor="#991B1B"
                    android:layout_marginBottom="12dp"/>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="• 사전 취소 없이 15분 이상 입실하지 않을 경우 자동 취소\n• 누적 노쇼 3회 발생 시, 해당 학기 공간 예약 권한이 30일간 즉시 정지됩니다."
                    android:textColor="#991B1B"
                    android:textSize="13sp"
                    android:lineSpacingExtra="5dp"
                    android:textStyle="bold"/>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

    </LinearLayout>
</ScrollView>